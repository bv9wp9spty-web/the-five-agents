# מפתחות API לצוות הסוכנים
# העתק קובץ זה ל-.env ומלא בערכים אמיתיים

# Anthropic - Claude API (לכל הסוכנים)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI - לשימוש של יובל (יצירת תמונות) ולמודלים נוספים
OPENAI_API_KEY=your_openai_api_key_here

# הערה: חן (חוקרת הרשת) משתמשת ב-WebSearch/WebFetch הפנימיים של Claude Code,
# ולא ב-API חיצוני בתשלום. אין צורך במפתחות נוספים עבורה.

# הגדרות כלליות
DEFAULT_MODEL=claude-opus-4-7
LOG_LEVEL=info
