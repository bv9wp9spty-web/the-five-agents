# מפתחות API לצוות הסוכנים
# העתק קובץ זה ל-.env ומלא בערכים אמיתיים

# Anthropic - Claude API (לכל הסוכנים)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI - לשימוש של יובל (יצירת תמונות) ולמודלים נוספים
OPENAI_API_KEY=your_openai_api_key_here

# חיפוש ומחקר - לשימוש של חן (החוקרת)
TAVILY_API_KEY=your_tavily_api_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# הגדרות כלליות
DEFAULT_MODEL=claude-opus-4-7
LOG_LEVEL=info
